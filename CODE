Login Form Code


from ._anvil_designer import LoginFormTemplate
from anvil import *
import anvil.server
import anvil.tables as tables
import anvil.tables.query as q
from anvil.tables import app_tables
import anvil.users

class LoginForm(LoginFormTemplate):
  def __init__(self, **properties):
    self.init_components(**properties)

  def login_button_click(self, **event_args):
    email = self.email_box.text.strip()
    password = self.password_box.text.strip()

    if not email or "@" not in email or "." not in email or " " in email:
      alert("Please enter a valid email address.", title="Error")
      return
    if not password or len(password) < 8:
      alert("Password must be at least 8 characters.", title="Error")
      return

    try:
      user = anvil.users.login_with_email(email, password)
      if user:
        role = user['role'] if 'role' in user else None
        if not role:
          alert("No role assigned. Please sign up again.", title="Error")
          open_form("SignUpForm")
          return
        self.redirect_by_role(user)
      else:
        alert("Invalid credentials.", title="Error")
    except Exception as e:
      alert(f"Login failed: {e}", title="Error")

  def signup_button_click(self, **event_args):
    open_form("SignUpForm")

  def redirect_by_role(self, user):
    if user['role'] == "Intern":
      open_form("InternForm")
    elif user['role'] == "Manager":
      open_form("ManagerForm")




